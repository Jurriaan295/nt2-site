---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Nederlandse les voor bedrijven in Friesland | Kristina Pichugina" description="Nederlandse les voor bedrijven in Friesland. Praktijkgerichte taaltraining voor anderstalige medewerkers, op locatie en op maat.">
  <section class="section">
    <div class="container">
      <p class="eyebrow">Voor bedrijven</p>
      <h1>Nederlandse les voor bedrijven in Friesland</h1>
      <p class="lead">Steeds meer bedrijven investeren in Nederlandse les voor medewerkers. Zeker in techniek, logistiek, productie en zorg maakt taal direct verschil in veiligheid, samenwerking en productiviteit.</p>
      <div class="grid grid-2" style="margin-top: 1.5rem;">
        <div class="surface card">
          <h3>Hoe werkt het?</h3>
          <p>Een traject start met intake, niveau-inschatting en een plan op maat. Daarna volgen lessen die aansluiten op dagelijkse werksituaties.</p>
        </div>
        <div class="surface card">
          <h3>Wat oefenen medewerkers?</h3>
          <p>Werkoverleggen, veiligheidsinstructies, samenwerken met collega's, klantcontact en vakspecifieke terminologie.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact | Kristina Tjalsma" description="Neem contact op met Kristina Tjalsma voor Nederlandse les op locatie in Friesland en Nederland. Stel je vraag of plan een intake. Reactie binnen 24 uur.">
  <section class="section">
    <div class="container grid grid-2">

      <div>
        <p class="eyebrow">Contact</p>
        <h1>Neem contact op</h1>
        <p class="lead">
          Heb je een vraag over Nederlandse les op locatie voor je bedrijf, of over online privéles als particulier? Ik denk graag met je mee en neem binnen 24 uur contact op.
        </p>
        <p class="muted" style="margin-bottom: 0.5rem; margin-top: 1.5rem;">Meer informatie</p>
        <ul class="meer-info-list">
          <li><a href="/nt2-voor-bedrijven">Nederlandse les voor bedrijven</a></li>
          <li><a href="/nt2-voor-particulieren">Nederlandse les voor particulieren</a></li>
          <li><a href="/nederlandse-les-friesland">Nederlandse les in Friesland</a></li>
          <li><a href="/faq">Veelgestelde vragen</a></li>
        </ul>
      </div>

      <div class="surface card" id="contact-card">
        <div id="contact-success" style="display:none; padding: 1rem 0;">
          <p style="font-size:1.5rem; margin-bottom:0.5rem;">✓</p>
          <p style="font-weight:700; font-size:1.1rem; margin-bottom:0;">Bedankt! Je bericht is verzonden.</p>
        </div>

        <form id="contact-form" method="post" action="https://formspree.io/f/maqajezy" class="contact-form">

          <input type="hidden" name="_subject" value="Nieuwe aanvraag via website" />

          <label for="naam">Naam</label>
          <input id="naam" name="naam" type="text" required autocomplete="name" />

          <label for="email">E-mail</label>
          <input id="email" name="email" type="email" required autocomplete="email" />

          <label for="onderwerp">Onderwerp</label>
          <input id="onderwerp" name="onderwerp" type="text" required />

          <label for="bericht">Bericht</label>
          <textarea id="bericht" name="bericht" rows="6" required></textarea>

          <button class="btn btn-primary" type="submit">Verstuur bericht</button>

        </form>
      </div>

    </div>

  </section>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const success = document.getElementById('contact-success');
    const card = document.getElementById('contact-card');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const data = new FormData(form);

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });

        if (res.ok) {
          form.style.display = 'none';
          if (success) success.style.display = 'block';
          card?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else {
          alert('Er is iets misgegaan. Probeer het opnieuw of stuur een e-mail.');
        }
      } catch {
        alert('Er is iets misgegaan. Controleer je internetverbinding.');
      }
    });
  </script>
</BaseLayout>

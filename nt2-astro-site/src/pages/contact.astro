---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact | Kristina Tjalsma" description="Neem contact op met Kristina Tjalsma voor NT2 les op locatie in Friesland en Nederland.">
  <section class="section">
    <div class="container grid grid-2">

      <div>
        <p class="eyebrow">Contact</p>
        <h1>Neem contact op</h1>
        <p class="lead">
          Heb je een vraag over Nederlandse les op locatie, een traject voor medewerkers of een intake?
          Ik denk graag met je mee.
        </p>

        <p>
          <strong>Kristina Tjalsma</strong><br />
          NT2 docent op locatie<br />
          Friesland en heel Nederland
        </p>
      </div>

      <div class="surface card">
        <form method="post" action="https://formspree.io/f/maqajezy" class="contact-form">

          <input type="hidden" name="_subject" value="Nieuwe aanvraag via website" />

          <label for="naam">Naam</label>
          <input id="naam" name="naam" type="text" required autocomplete="name" />

          <label for="email">E-mail</label>
          <input id="email" name="email" type="email" required autocomplete="email" />

          <label for="onderwerp">Onderwerp</label>
          <input id="onderwerp" name="onderwerp" type="text" required />

          <label for="bericht">Bericht</label>
          <textarea id="bericht" name="bericht" rows="6" required></textarea>

          <button class="btn btn-primary" type="submit">Verstuur bericht</button>

        </form>
      </div>

    </div>
  </section>
</BaseLayout>
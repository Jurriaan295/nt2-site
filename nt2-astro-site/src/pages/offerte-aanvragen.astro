---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Offerte aanvragen | Nederlandse les op locatie – Kristina Tjalsma" description="Vraag een vrijblijvende offerte aan voor Nederlandse les op locatie in Friesland of Nederland. Maatwerk voor bedrijven en particulieren. Reactie binnen 24 uur.">
  <section class="section">
    <div class="container grid grid-2">

      <div>
        <p class="eyebrow">Offerte aanvragen</p>
        <h1>Vraag een offerte aan voor Nederlandse les op locatie</h1>
        <p class="lead">
          Ik maak een voorstel op maat op basis van locatie, aantal deelnemers, niveau en leerdoelen.
        </p>
        <p>
          Binnen 24 uur ontvang je een reactie.
        </p>
      </div>

      <div class="surface card" id="offerte-card">
        <div id="offerte-success" style="display:none; padding: 1rem 0;">
          <p style="font-size:1.5rem; margin-bottom:0.5rem;">✓</p>
          <p style="font-weight:700; font-size:1.1rem; margin-bottom:0;">Bedankt! Je aanvraag is verzonden.</p>
        </div>

        <!-- Type kiezer -->
        <div class="offerte-type-kiezer" style="display:flex; gap:0.5rem; margin-bottom:1.25rem;">
          <button type="button" id="btn-particulier" class="btn btn-primary offerte-type-btn offerte-type-active" onclick="setType('particulier')">Particulier</button>
          <button type="button" id="btn-zakelijk" class="btn offerte-type-btn" onclick="setType('zakelijk')">Zakelijk</button>
        </div>

        <form id="offerte-form" method="post" action="https://formspree.io/f/maqajezy" class="contact-form">

          <input type="hidden" name="_subject" value="Nieuwe offerte aanvraag" />
          <input type="hidden" name="type-klant" id="type-klant-hidden" value="Particulier" />

          <label>Naam
            <input name="naam" required />
          </label>

          <label>E-mail
            <input type="email" name="email" required />
          </label>

          <label>Telefoon
            <input name="telefoon" />
          </label>

          <div class="zakelijk-velden" style="display:none;">
            <label>Organisatie
              <input name="organisatie" />
            </label>

            <label>Locatie
              <input name="locatie" />
            </label>

            <label>Aantal deelnemers
              <input name="deelnemers" />
            </label>

            <label>Type aanvraag
              <select name="type-aanvraag">
                <option>Nederlandse les op locatie</option>
                <option>Individuele les</option>
                <option>Anders</option>
              </select>
            </label>
          </div>

          <label>Bericht
            <textarea name="bericht"></textarea>
          </label>

          <button class="btn btn-primary" type="submit">Verstuur aanvraag</button>

        </form>
      </div>

    </div>
  </section>

  <script>
    function setType(type: string) {
      const zakelijkVelden = document.querySelector('.zakelijk-velden') as HTMLElement;
      const btnParticulier = document.getElementById('btn-particulier');
      const btnZakelijk = document.getElementById('btn-zakelijk');
      const hiddenType = document.getElementById('type-klant-hidden') as HTMLInputElement;

      if (type === 'zakelijk') {
        zakelijkVelden.style.display = 'block';
        btnZakelijk?.classList.add('btn-primary', 'offerte-type-active');
        btnZakelijk?.classList.remove('btn-outline');
        btnParticulier?.classList.remove('btn-primary', 'offerte-type-active');
        btnParticulier?.classList.add('btn-outline');
        hiddenType.value = 'Zakelijk';
      } else {
        zakelijkVelden.style.display = 'none';
        btnParticulier?.classList.add('btn-primary', 'offerte-type-active');
        btnParticulier?.classList.remove('btn-outline');
        btnZakelijk?.classList.remove('btn-primary', 'offerte-type-active');
        btnZakelijk?.classList.add('btn-outline');
        hiddenType.value = 'Particulier';
      }
    }

    // Maak setType globaal beschikbaar
    (window as any).setType = setType;

    const form = document.getElementById('offerte-form') as HTMLFormElement;
    const success = document.getElementById('offerte-success');
    const card = document.getElementById('offerte-card');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const data = new FormData(form);

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });

        if (res.ok) {
          form.style.display = 'none';
          if (success) success.style.display = 'block';
          card?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else {
          alert('Er is iets misgegaan. Probeer het opnieuw of stuur een e-mail.');
        }
      } catch {
        alert('Er is iets misgegaan. Controleer je internetverbinding.');
      }
    });
  </script>
</BaseLayout>

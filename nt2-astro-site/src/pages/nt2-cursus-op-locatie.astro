---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="NT2 cursus op locatie | Kristina Pichugina" description="NT2 cursus op locatie voor bedrijven, gemeenten en particulieren. Praktische Nederlandse les met maatwerk en persoonlijke begeleiding.">
  <section class="section">
    <div class="container grid grid-2">
      <div>
        <p class="eyebrow">Dienst</p>
        <h1>NT2 cursus op locatie</h1>
        <p class="lead">Praktische Nederlandse les voor anderstaligen, afgestemd op dagelijkse situaties, werkvloercommunicatie en leerdoelen.</p>
      </div>
      <div class="surface card">
        <h3>Waarom op locatie?</h3>
        <p>Leren in de eigen omgeving maakt de lessen concreter en beter toepasbaar. Dat zorgt vaak voor sneller resultaat en meer zelfvertrouwen.</p>
      </div>
    </div>
  </section>
  <section class="section-tight">
    <div class="container grid grid-3">
      <article class="surface card"><h3>Bedrijven</h3><p>Voor medewerkers die beter willen communiceren op de werkvloer.</p></article>
      <article class="surface card"><h3>Gemeenten</h3><p>Voor deelnemers die hun Nederlands praktisch willen verbeteren.</p></article>
      <article class="surface card"><h3>Particulieren</h3><p>Voor wie persoonlijke en flexibele begeleiding zoekt.</p></article>
    </div>
  </section>
</BaseLayout>

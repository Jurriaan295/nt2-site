---
import BaseLayout from '../layouts/BaseLayout.astro';
const faqs = [
  ['Wat kost een docent Nederlands op locatie voor bedrijven?', 'De kosten zijn afhankelijk van het aantal deelnemers en de duur van het traject. Op basis daarvan maak ik een passend voorstel dat aansluit bij jullie wensen en doelen.'],
  ['Kunnen jullie Nederlandse les op maat aanbieden voor medewerkers?', 'Ja. De lessen worden afgestemd op niveau, branche en dagelijkse werkzaamheden. Denk aan basiscommunicatie, vaktaal of klantgesprekken.'],
  ['Geef je Nederlandse les op onze eigen locatie?', 'Ja, ik geef Nederlandse les op locatie bij bedrijven in Friesland en in de rest van Nederland. Online of hybride is ook mogelijk.'],
  ['Voor welk niveau zijn de cursussen geschikt?', 'De cursussen zijn geschikt voor alle niveaus, van A0/A1 tot B2/C1. Vooraf kan een intake of taaltoets worden gedaan.'],
  ['Hoe snel kunnen we starten?', 'In de meeste gevallen kan een traject binnen 1 tot 2 weken starten.'],
  ['Hoe groot mogen de groepen zijn?', 'De ideale groepsgrootte ligt tussen 4 en 8 deelnemers. Individuele begeleiding is ook mogelijk.'],
  ['Geef je ook les aan expats of arbeidsmigranten?', 'Ja, ik werk regelmatig met anderstalige medewerkers, expats en arbeidsmigranten.'],
  ['Wordt de voortgang gemeten?', 'Ja, met intake, tussentijdse evaluaties, praktische opdrachten en indien gewenst rapportage.'],
  ['Kunnen lessen gecombineerd worden met werkgerichte situaties?', 'Ja, de lessen sluiten juist aan op werkoverleggen, veiligheidsinstructies, klantcontact en samenwerking op de werkvloer.'],
  ['Zijn flexibele lestijden mogelijk?', 'Ja. Lessen kunnen tijdens werktijd, in ploegendiensten of aan het begin of einde van de werkdag plaatsvinden.']
];
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(([q, a]) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a }
  }))
};
---
<BaseLayout title="Veelgestelde vragen | Nederlandse les op locatie – Kristina Tjalsma" description="Veelgestelde vragen over Nederlandse les op locatie, NT2 cursussen voor bedrijven en maatwerktrajecten in Friesland en Nederland.">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
  <section class="section">
    <div class="container">
      <p class="eyebrow">FAQ</p>
      <h1>Veelgestelde vragen over Nederlandse les op locatie</h1>
      <p class="lead" style="margin-bottom: 2rem;">Antwoorden op de meest gestelde vragen over Nederlandse les op locatie, kosten, niveaus en werkwijze.</p>

      <h2 style="font-size: 1.15rem; margin-bottom: 1rem; color: var(--muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">Kosten en opstart</h2>
      <div class="grid" style="margin-bottom: 2rem;">
        {faqs.slice(0, 2).map(([q, a]) => (
          <article class="surface faq-item">
            <h3>{q}</h3>
            <p>{a}</p>
          </article>
        ))}
      </div>

      <h2 style="font-size: 1.15rem; margin-bottom: 1rem; color: var(--muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">Werkwijze en lessen</h2>
      <div class="grid" style="margin-bottom: 2rem;">
        {faqs.slice(2, 6).map(([q, a]) => (
          <article class="surface faq-item">
            <h3>{q}</h3>
            <p>{a}</p>
          </article>
        ))}
      </div>

      <h2 style="font-size: 1.15rem; margin-bottom: 1rem; color: var(--muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">Deelnemers en planning</h2>
      <div class="grid" style="margin-bottom: 2rem;">
        {faqs.slice(6).map(([q, a]) => (
          <article class="surface faq-item">
            <h3>{q}</h3>
            <p>{a}</p>
          </article>
        ))}
      </div>

      <div style="margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--line);">
        <p class="muted" style="margin-bottom: 0.5rem;">Meer informatie:</p>
        <p style="margin: 0;">
          <a href="/nt2-voor-bedrijven">Nederlandse les voor bedrijven</a> &nbsp;·&nbsp;
          <a href="/nt2-voor-particulieren">Nederlandse les voor particulieren</a> &nbsp;·&nbsp;
          <a href="/nederlandse-les-friesland">Nederlandse les in Friesland</a> &nbsp;·&nbsp;
          <a href="/offerte-aanvragen">Offerte aanvragen</a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

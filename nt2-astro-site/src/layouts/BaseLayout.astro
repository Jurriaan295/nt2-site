---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Favicon -->
    <link rel="icon" type="image/jpeg" href="/images/favicon.jpeg" />
    <link rel="apple-touch-icon" href="/images/logo2.png" />

    <!-- Open Graph / Social media -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://taaldiewerkt.nl/images/kristina.jpeg" />
    <meta property="og:image:width" content="540" />
    <meta property="og:image:height" content="620" />
    <meta property="og:site_name" content="TaalPartner – Nederlandse les op locatie" />
    <meta property="og:locale" content="nl_NL" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://taaldiewerkt.nl/images/kristina.jpeg" />

    <slot name="head" />

    <!-- Google Analytics 4 -->
    <!-- ⚠️ Vervang G-86KG3LZ3J9 door jouw Measurement ID uit Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-86KG3LZ3J9"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-86KG3LZ3J9', {
        anonymize_ip: true
      });
    </script>

    <!-- Microsoft Clarity -->
    <!-- ⚠️ Vervang wgdm1kdc8s door jouw Project ID uit Microsoft Clarity -->
    <script is:inline>
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "wgdm1kdc8s");
    </script>

    <!-- Schema.org: LocalBusiness + EducationalOrganization -->
    <script type="application/ld+json" set:html={JSON.stringify([
      {
        '@context': 'https://schema.org',
        '@type': ['EducationalOrganization', 'LocalBusiness'],
        '@id': 'https://taaldiewerkt.nl/#organization',
        name: 'TaalPartner – Kristina Tjalsma',
        description: 'Nederlandse les op locatie voor bedrijven en particulieren in Friesland en heel Nederland.',
        url: 'https://taaldiewerkt.nl',
        logo: 'https://taaldiewerkt.nl/images/logo2.png',
        image: 'https://taaldiewerkt.nl/images/kristina.jpeg',
        email: 'englishdutchtutor@gmail.com',
        priceRange: '€€',
        address: {
          '@type': 'PostalAddress',
          addressLocality: 'Leeuwarden',
          addressRegion: 'Friesland',
          addressCountry: 'NL'
        },
        areaServed: [
          { '@type': 'State', name: 'Friesland' },
          { '@type': 'Country', name: 'Nederland' }
        ],
        knowsAbout: ['NT2', 'Nederlandse les', 'in-company taaltraining', 'Nederlands leren', 'taaltraining op locatie', 'NT2 cursus', 'expat begeleiding'],
        sameAs: ['https://www.instagram.com/englishdutchtutor'],
        founder: {
          '@type': 'Person',
          name: 'Kristina Tjalsma',
          jobTitle: 'NT2-docent',
          email: 'englishdutchtutor@gmail.com',
          image: 'https://taaldiewerkt.nl/images/kristina.jpeg',
          sameAs: ['https://www.instagram.com/englishdutchtutor']
        }
      }
    ])}></script>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- CTA klik-tracking voor Google Analytics -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('a.btn, button.btn').forEach(function (el) {
          el.addEventListener('click', function () {
            if (typeof gtag !== 'undefined') {
              gtag('event', 'klik_cta', {
                event_category: 'CTA',
                event_label: el.textContent.trim().substring(0, 60),
                event_destination: el.getAttribute('href') || ''
              });
            }
          });
        });
      });
    </script>
  </body>
</html>

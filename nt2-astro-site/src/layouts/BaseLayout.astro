---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/images/favicon.png" />
    <link rel="apple-touch-icon" href="/images/favicon.png" />

    <!-- Open Graph / Social media -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://taaldiewerkt.nl/images/kristina.webp" />
    <meta property="og:image:width" content="540" />
    <meta property="og:image:height" content="620" />
    <meta property="og:site_name" content="TaalPartner – Nederlandse les op locatie" />
    <meta property="og:locale" content="nl_NL" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://taaldiewerkt.nl/images/kristina.webp" />

    <slot name="head" />

    <!-- Google Analytics 4 – alleen op productiedomain -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-86KG3LZ3J9"></script>
    <script is:inline>
      if (window.location.hostname === 'taaldiewerkt.nl') {
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-86KG3LZ3J9', {
          anonymize_ip: true
        });
      }
    </script>

    <!-- Microsoft Clarity – alleen op productiedomain -->
    <script is:inline>
      if (window.location.hostname === 'taaldiewerkt.nl') {
        (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", "wgdm1kdc8s");
      }
    </script>

    <!-- Schema.org: LocalBusiness + EducationalOrganization -->
    <script type="application/ld+json" set:html={JSON.stringify([
      {
        '@context': 'https://schema.org',
        '@type': ['EducationalOrganization', 'LocalBusiness'],
        '@id': 'https://taaldiewerkt.nl/#organization',
        name: 'TaalPartner – Kristina Tjalsma',
        description: 'Nederlandse les op locatie voor bedrijven en particulieren in Friesland en heel Nederland.',
        url: 'https://taaldiewerkt.nl',
        logo: 'https://taaldiewerkt.nl/images/logo2.png',
        image: 'https://taaldiewerkt.nl/images/kristina.webp',
        email: 'englishdutchtutor@gmail.com',
        priceRange: '€€',
        address: {
          '@type': 'PostalAddress',
          addressLocality: 'Leeuwarden',
          addressRegion: 'Friesland',
          addressCountry: 'NL'
        },
        areaServed: [
          { '@type': 'State', name: 'Friesland' },
          { '@type': 'Country', name: 'Nederland' }
        ],
        knowsAbout: ['NT2', 'Nederlandse les', 'in-company taaltraining', 'Nederlands leren', 'taaltraining op locatie', 'NT2 cursus', 'expat begeleiding'],
        sameAs: ['https://www.instagram.com/englishdutchtutor'],
        aggregateRating: {
          '@type': 'AggregateRating',
          ratingValue: '5',
          reviewCount: '12',
          bestRating: '5',
          worstRating: '1'
        },
        founder: {
          '@type': 'Person',
          name: 'Kristina Tjalsma',
          jobTitle: 'NT2-docent',
          email: 'englishdutchtutor@gmail.com',
          image: 'https://taaldiewerkt.nl/images/kristina.webp',
          sameAs: ['https://www.instagram.com/englishdutchtutor']
        }
      }
    ])}></script>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Uitklapbare contactknop -->
    <div class="contact-fab" id="contactFab">
      <!-- Sub-knoppen -->
      <a href="mailto:englishdutchtutor@gmail.com" class="contact-fab-item fab-email" aria-label="Stuur een e-mail">
        <svg viewBox="-4 -2 32 28" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><polyline points="2,4 12,13 22,4"/></svg>
      </a>
      <a href="https://wa.me/31515796206" class="contact-fab-item fab-whatsapp" target="_blank" rel="noopener" aria-label="Stuur een WhatsApp bericht">
        <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
          <circle cx="24" cy="24" r="24" fill="#25D366"/>
          <!-- Witte speech bubble -->
          <path fill="white" d="M24 11C16.82 11 11 16.82 11 24c0 2.55.73 4.94 2 6.97L11 37l6.18-1.98A13 13 0 0 0 24 37c7.18 0 13-5.82 13-13S31.18 11 24 11z"/>
          <!-- Groene telefoon (uitgesneden uit witte bubbel) -->
          <path fill="#25D366" d="M19.2 16.6c-.26-.6-.54-.62-.8-.63l-.68-.01c-.23 0-.61.09-.93.44-.32.35-1.22 1.2-1.22 2.92s1.25 3.39 1.43 3.62c.17.23 2.44 3.87 5.99 5.27 2.96 1.17 3.56.94 4.2.88.64-.06 2.07-.85 2.36-1.66.28-.82.28-1.52.2-1.67-.08-.14-.32-.24-.68-.41l-2.38-1.15c-.35-.17-.58-.26-.83.26-.24.51-.94 1.21-1.15 1.45-.21.24-.42.27-.77.09-.35-.18-1.48-.55-2.82-1.75-1.04-.93-1.74-2.08-1.95-2.43-.21-.35-.02-.54.16-.71.16-.16.35-.41.53-.62.18-.21.24-.35.35-.59.11-.23.06-.44-.03-.62l-1.23-2.71z"/>
        </svg>
      </a>
      <a href="https://www.instagram.com/englishdutchtutor" class="contact-fab-item fab-instagram" target="_blank" rel="noopener" aria-label="Bekijk Instagram">
        <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <radialGradient id="ig-grad" cx="30%" cy="107%" r="150%">
              <stop offset="0%" stop-color="#fdf497"/>
              <stop offset="10%" stop-color="#fdf497"/>
              <stop offset="50%" stop-color="#fd5949"/>
              <stop offset="68%" stop-color="#d6249f"/>
              <stop offset="100%" stop-color="#285AEB"/>
            </radialGradient>
          </defs>
          <circle cx="24" cy="24" r="24" fill="url(#ig-grad)"/>
          <rect x="13" y="13" width="22" height="22" rx="6" ry="6" fill="none" stroke="white" stroke-width="2.2"/>
          <circle cx="24" cy="24" r="5.5" fill="none" stroke="white" stroke-width="2.2"/>
          <circle cx="30.5" cy="17.5" r="1.4" fill="white"/>
        </svg>
      </a>
      <!-- Hoofdknop -->
      <button class="contact-fab-main" id="contactFabBtn" aria-label="Contact opties">
        <svg class="icon-open" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        <svg class="icon-close" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <!-- Contact FAB logica -->
    <script is:inline>
      var fab = document.getElementById('contactFab');
      var fabBtn = document.getElementById('contactFabBtn');
      fabBtn.addEventListener('click', function () {
        fab.classList.toggle('open');
      });
      document.addEventListener('click', function (e) {
        if (!fab.contains(e.target)) fab.classList.remove('open');
      });
    </script>


    <!-- CTA klik-tracking voor Google Analytics -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('a.btn, button.btn').forEach(function (el) {
          el.addEventListener('click', function () {
            if (typeof gtag !== 'undefined') {
              gtag('event', 'klik_cta', {
                event_category: 'CTA',
                event_label: el.textContent.trim().substring(0, 60),
                event_destination: el.getAttribute('href') || ''
              });
            }
          });
        });
      });
    </script>
  </body>
</html>
